# ═══════════════════════════════════════════════════════
# 必需
# ═══════════════════════════════════════════════════════

# OpenRouter API key (get one at https://openrouter.ai/)
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# ═══════════════════════════════════════════════════════
# 数据来源（三选一）
# ═══════════════════════════════════════════════════════

# 方式 A: 本地文件夹（绝对路径或相对路径）
# DATA_DIR=D:\Projects\my-site\docs
# DATA_DIR=./my-content

# 方式 B: GitHub 仓库文件夹（自动 sparse clone + cache）
# DATA_DIR=https://github.com/user/repo/tree/main/docs

# 方式 C: 不设置，使用默认 knowledge-base/ 目录

# ═══════════════════════════════════════════════════════
# 模型配置
# ═══════════════════════════════════════════════════════

# LLM 模型列表（逗号分隔，按优先级排序）
# 默认: anthropic/claude-sonnet-4.6,google/gemini-2.0-flash-001
# OPENROUTER_MODEL=openai/gpt-4o-mini,anthropic/claude-sonnet-4.6

# 嵌入模型（中文内容推荐用 BAAI/bge-m3）
# 默认: all-MiniLM-L6-v2（英文优化，384维，~80MB）
# EMBEDDING_MODEL=BAAI/bge-m3

# ═══════════════════════════════════════════════════════
# 安全
# ═══════════════════════════════════════════════════════

# CORS 允许的域名（生产环境建议设置为你的网站域名）
# CORS_ORIGIN=https://your-site.com

# 频率限制 — 每个 IP 在时间窗口内的最大请求数
# RATE_LIMIT_CHAT_MAX=20          # 聊天: 20次/分钟
# RATE_LIMIT_CHAT_WINDOW=60
# RATE_LIMIT_SUGGEST_MAX=30       # 追问: 30次/分钟
# RATE_LIMIT_SUGGEST_WINDOW=60
# RATE_LIMIT_REBUILD_MAX=3        # 重建索引: 3次/5分钟
# RATE_LIMIT_REBUILD_WINDOW=300

# 最大并发 LLM 调用数
# MAX_CONCURRENT_LLM=5

# 重建索引的简单密钥（生产环境建议用 nginx basic auth）
# REBUILD_SECRET=your-secret-here

# ═══════════════════════════════════════════════════════
# 服务
# ═══════════════════════════════════════════════════════

# 服务端口（默认 8000）
# PORT=8000
